<%- include("../partials/header") %>

<div class="admin-sermon-container admin-sermons-page">

  <h1>Admin Sermons</h1>
  <p class="admin-subtitle">Create and manage sermons.</p>

  <!-- CREATE SERMON -->
  <div class="admin-card">
    <form
      method="POST"
      action="/admin/sermons"
      enctype="multipart/form-data"
      class="admin-form"
    >

      <input
        type="text"
        name="title"
        placeholder="Sermon title"
        required
      >

      <input
        name="bible_passage"
        placeholder="Sermon bible passage"
      >

      <input
        type="date"
        name="sermon_date"
        required
      >

      <input
        type="text"
        name="speaker"
        placeholder="Speaker name"
      >

      <input
        type="file"
        name="video"
        accept="video/*"
        required
      >

      <button type="submit" class="btn-accent">Add Sermon</button>

    </form>
  </div>

  <!-- SERMON LIST -->
  <h2 class="admin-section-title">Existing Sermons</h2>

  <% if (sermons.length === 0) { %>
    <p class="empty-state">No sermons yet.</p>
  <% } else { %>

    <div class="admin-sermon-grid">
      <% sermons.forEach(sermon => { %>

        <div class="admin-sermon-card">

          <h3>
            <a href="/sermons/<%= sermon.slug %>" target="_blank">
              <%= sermon.title %>
            </a>
          </h3>

          <p class="sermon-speaker">
            By <em><%= sermon.speaker %></em>
          </p>

          <p class="sermon-passage"><%= sermon.bible_passage %></p>

          <% if (sermon.video) { %>
            <video controls>
              <source src="/uploads/sermons/<%= sermon.video %>" type="video/mp4">
            </video>
          <% } %>

          <p class="sermon-date">
            <strong>Date:</strong>
            <%= new Date(sermon.sermon_date).toDateString() %>
          </p>

          <p class="sermon-stats">
            💬 <%= sermon.commentCount %> |
            👍 <%= sermon.likeCount %>
          </p>

          <% if (user && (user.role === "admin" || user.role === "super_admin")) { %>
            <div class="sermon-actions">

              <form
                action="/admin/sermons/<%= sermon.slug %>/toggleSermonComments"
                method="POST"
              >
                <button type="submit" class = "btn-toggle">
                  <%= sermon.comment_enabled ? "🔒 lock Comments" : "🔓 Unlock Comments" %>
                </button>
              </form>

              <a href="/admin/sermons/<%= sermon.slug %>/edit">
                <button type="button" class = "btn-accent">✏️Edit</button>
              </a>

              <form
                action="/admin/sermons/<%= sermon.slug %>/delete"
                method="POST"
              >
                <button
                  type="submit"
                  class = "btn-danger"
                  onclick="return confirm('Are you sure?')"
                >
                  Delete
                </button>
              </form>

            </div>
          <% } %>

        </div>

      <% }) %>
    </div>

  <% } %>

</div>

<%- include("../partials/footer") %>
