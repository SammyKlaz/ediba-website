<%- include("../../partials/header") %>

<div class="receipt-form-container">
  <h2 class="section-title">Add Receipt</h2>

  <form method="POST" action="/admin/receipts" enctype="multipart/form-data" class="receipt-form">
    <input type="text" name="title" placeholder="Payment title" required>

    <input type="number" name="amount" step="0.01" placeholder="Amount">

    <textarea name="description" placeholder="Description"></textarea>

    <input type="file" name="image" required>

    <button class="btn-accent">Save Receipt</button>
  </form>
</div>

<%- include("../../partials/footer") %>
