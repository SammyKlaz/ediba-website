<%- include("../../partials/header") %>

<section class="admin-feature-page container my-5">
  <div class="admin-page-header">
    <h1 class="section-title">Add Arm or Service-group Contact</h1>
    <p>Add a leader or officer under an arm or Service-group</p>
  </div>

  <div class="admin-form-wrapper">
    <form action="/admin/ministry-contacts" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="form-group">
        <label for="ministry_id">Arm/Service-group</label>
        <select id="ministry_id" name="ministry_id" required>
          <option value="">Select Arm/Service-group</option>
          <% ministries.forEach(ministry => { %>
            <option value="<%= ministry.id %>"><%= ministry.name %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="role_title">Role Title</label>
        <input type="text" id="role_title" name="role_title" required placeholder="Example: President, Secretary, Choir Mistress">
      </div>

      <div class="form-group">
        <label for="full_name">Full Name</label>
        <input type="text" id="full_name" name="full_name" required placeholder="Enter full name">
      </div>

      <div class="form-group">
        <label for="phone">Phone Number</label>
        <input type="text" id="phone" name="phone" placeholder="Enter phone number">
      </div>

      <div class="form-group">
        <label for="whatsapp">WhatsApp Number</label>
        <input type="text" id="whatsapp" name="whatsapp" placeholder="Enter WhatsApp number">
      </div>

      <div class="form-group">
        <label for="email">Email Address</label>
        <input type="email" id="email" name="email" placeholder="Enter email address">
      </div>

      <div class="form-group">
        <label for="portrait">Portrait Image</label>
        <input type="file" id="portrait" name="portrait" accept="image/*">
      </div>

      <div class="form-group">
        <label for="notes">Notes</label>
        <textarea id="notes" name="notes" rows="4" placeholder="Optional notes"></textarea>
      </div>

      <div class="form-group">
        <label for="display_order">Display Order</label>
        <input type="number" id="display_order" name="display_order" value="0" min="0" step="1" placeholder="0">
      </div>

      <div class="form-group">
        <label for="is_active">Status</label>
        <select id="is_active" name="is_active">
          <option value="true" selected>Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>

      <div class="admin-card-actions">
        <button type="submit" class="btn-accent">Save Contact</button>
        <a href="/admin/ministry-contacts" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</section>

<%- include("../../partials/footer") %>