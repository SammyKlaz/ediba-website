<%- include("../../partials/header") %>

<section class="container my-5">
  <div class="admin-page-header">
    <h1 class="section-title">Manage Ministry Contacts</h1>
    <p>Manage leaders and contact details for all ministries and arms.</p>
  </div>

  <div class="admin-actions mb-4">
    <a href="/admin/ministry-contacts/new" class="btn-accent">Add Ministry Contact</a>
    <a href="/admin/ministries" class="btn-accent">Manage Ministries</a>
    <a href="/admin/church-contacts" class="btn-accent">Manage Church Contacts</a>
  </div>

  <% if (contacts.length === 0) { %>
    <div class="empty-state">
      <p>No ministry contacts have been added yet.</p>
    </div>
  <% } else { %>
    <div class="admin-list">
      <% contacts.forEach(contact => { %>
        <div class="admin-card">
          <div class="admin-card-body">
            <% if (contact.portrait_url) { %>
              <img
                src="<%= contact.portrait_url %>"
                alt="<%= contact.full_name %>"
                class="contact-photo"
              >
            <% } %>

            <h3><%= contact.role_title %></h3>

            <p>
              <strong>Ministry:</strong>
              <%= contact.ministry_name %>
            </p>

            <p>
              <strong>Name:</strong>
              <%= contact.full_name %>
            </p>

            <% if (contact.phone) { %>
              <p><strong>Phone:</strong> <%= contact.phone %></p>
            <% } %>

            <% if (contact.whatsapp) { %>
              <p><strong>WhatsApp:</strong> <%= contact.whatsapp %></p>
            <% } %>

            <% if (contact.email) { %>
              <p><strong>Email:</strong> <%= contact.email %></p>
            <% } %>

            <p>
              <strong>Order:</strong>
              <%= contact.display_order %>
            </p>

            <p>
              <strong>Status:</strong>
              <%= contact.is_active ? "Active" : "Inactive" %>
            </p>

            <% if (contact.notes) { %>
              <p><%= contact.notes %></p>
            <% } %>

            <div class="admin-card-actions">
              <a href="/admin/ministry-contacts/<%= contact.id %>/edit" class="btn-accent">Edit</a>

              <form action="/admin/ministry-contacts/<%= contact.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this ministry contact?');">
                <button type="submit" class="btn-danger">Delete</button>
              </form>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../../partials/footer") %>