<%- include("../../partials/header") %>

<section class="admin-feature-page container my-5">
  <div class="admin-page-header">
    <h1 class="section-title">Add Ministry</h1>
    <p>Create a new ministry or arm that will appear on the Get Involved and Contact pages.</p>
  </div>

  <div class="admin-form-wrapper">
    <form action="/admin/ministries" method="POST" class="admin-form">
      <div class="form-group">
        <label for="name">Name of Arm or Group</label>
        <input type="text" id="name" name="name" required placeholder="Enter ministry name">
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="5" placeholder="Write a short description of the ministry"></textarea>
      </div>

      <div class="form-group">
        <label for="display_order">Display Order</label>
        <input type="number" id="display_order" name="display_order" value="0" min="0" step="1" placeholder="0">
      </div>

      <div class="form-group">
        <label for="is_active">Status</label>
        <select id="is_active" name="is_active">
          <option value="true" selected>Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>

      <div class="admin-card-actions">
        <button type="submit" class="btn-accent">Save</button>
        <a href="/admin/ministries" class="btn-secondary">Cancel</a>
      </div>
    </form>
  </div>
</section>

<%- include("../../partials/footer") %> 