

<%- include("../partials/header") %>

<% if (error && error.length) { %>
  <p class="auth-error"><%= error[0] %></p>
<% } %>
<% if (success && success.length) { %>
  <p class="auth-success"><%= success[0] %></p>
<% } %>

<div class="admin-birthday-edit">
  <div>
    <h2>Edit Birthday</h2>

    <form
      action="/admin/birthdays/<%= birthday.id %>/edit"
      method="POST"
      enctype="multipart/form-data"
    >

      <input
        type="text"
        name="name"
        value="<%= birthday.name %>"
        required
      >

      <input
        type="date"
        name="birth_date"
        value="<%= birthday.birth_date.toISOString().split('T')[0] %>"
        required
      >

      <select name="arm" required>
        <option value="">Select Arm or Department</option>
        <option value="MCA">MCA</option>
        <option value="Womens Guild">WOMENS GUILD</option>
        <option value="CGIT">CGIT</option>
        <option value="PYPAN">PYPAN</option>
        <option value="Children Department">CHILDREN DEPARTMENT</option>
      </select>
      <select name="year" required>
        <option value="<%= birthday.year %>" selected>
          <%= birthday.year %>
        </option>
        <option value="<%= birthday.year + 1 %>">
          <%= birthday.year + 1 %>
        </option>
      </select>

      <input
        type="text"
        name="position"
        value="<%= birthday.position || '' %>"
      >

      <label>
        Active
        <input
          type="checkbox"
          name="is_active"
          value="true"
          <%= birthday.is_active ? "checked" : "" %>
        >
      </label>

      <input type="file" name="photo" accept="image/*">

      <button type="submit">Update</button>

    </form>
  </div>
</div>


<%- include("../partials/footer") %>
