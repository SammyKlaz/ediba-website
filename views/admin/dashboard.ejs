<%- include("../partials/header") %>

<div class="container mt-5">
  <h1 class="section-title">⚙️ Admin Dashboard</h1>
  <p class="lead">Welcome to the admin panel. Manage all church content from here.</p>

  <div class="row">

    <div class="col-md-6 col-lg-4 mb-4">
        <div class="dashboard-card">
          <h3>🏠 Manage Home</h3>
          <p class="mb-3">Update homepage images (hero, about, ministries)</p>
          <a href="/admin/homepage-images" class="btn-accent">Manage Home</a>
        </div>
      </div>

    <div class="col-md-6 col-lg-4 mb-4">
      <div class="dashboard-card">
        <h3>📅 Events</h3>
        <p class="mb-3">Create, edit, and delete church events</p>
        <a href="/admin/events" class="btn-accent">Manage Events</a>
      </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-4">
      <div class="dashboard-card">
        <h3>📖 Sermons</h3>
        <p class="mb-3">Upload and manage sermons with videos</p>
        <a href="/admin/sermons" class="btn-accent">Manage Sermons</a>
      </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-4">
      <div class="dashboard-card">
        <h3>ℹ️ About Page</h3>
        <p class="mb-3">Update church information and ministries</p>
        <a href="/admin/about" class="btn-accent">Manage About</a>
      </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-4">
      <div class="dashboard-card">
        <h3>💰 Giving</h3>
        <p class="mb-3">Manage donation accounts and projects</p>
        <a href="/admin/give" class="btn-accent">Manage Giving</a>
      </div>
    </div>


    <div class="col-md-6 col-lg-4 mb-4">
      <div class="dashboard-card">
        <h3>🎂 Birthdays</h3>
        <p class="mb-3">Upload and manage birthday photos</p>
        <a href="/admin/birthdays" class="btn-accent">Manage Birthdays</a>
      </div>
    </div>  

       <div class="col-md-6 col-lg-4 mb-4">
      <div class="dashboard-card">
        <h3>🧾 Receipts</h3>
        <p class="mb-3">View and Manage receipts of payments</p>
        <a href="/admin/receipts/index" class="btn-accent">Manage Receipts</a>
      </div>
    </div>

    

  </div>
</div>

<%- include("../partials/footer") %>
