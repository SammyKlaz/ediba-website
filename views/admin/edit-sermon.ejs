

<%- include("../partials/header") %>

<% if (error && error.length) { %>
  <p class="auth-error"><%= error[0] %></p>
<% } %>
<% if (success && success.length) { %>
  <p class="auth-success"><%= success[0] %></p>
<% } %>

<div class = "admin-page"> 

  <div class="admin-sermon-edit">
    <div class="admin-sermon-edit-inner">

    <h1>Edit Sermon</h1>
  <p>Edit your sermon.</p>

  <form
    method="POST"
    action="/admin/sermons/<%= sermon.slug %>/edit"
    enctype="multipart/form-data"
  >
    <input
      type="text"
      name="title"
      placeholder="Sermon title"
      required
      value="<%= sermon.title %>"
    >

    <textarea
      name="bible_passage"
      placeholder="Sermon bible passage"
    ><%= sermon.bible_passage %></textarea>

    <% const sd = sermon.sermon_date ? new Date(sermon.sermon_date).toISOString().slice(0,10) : '' %>
    <input
      type="date"
      name="sermon_date"
      required
      value="<%= sd %>"
    >

    <input
      type="text"
      name="speaker"
      placeholder="Speaker name"
      value="<%= sermon.speaker %>"
    >

    <% if (sermon.video) { %>
      <p>Current video: <a href="/uploads/sermons/<%= sermon.video %>" target="_blank">View</a></p>
    <% } %>

    <input
      type="file"
      name="video"
      accept="video/*"
    >

    <!-- Keep existing filename in a hidden field so controller can keep it when no new file is uploaded -->
    <input type="hidden" name="video" value="<%= sermon.video %>">

    <button type="submit">Update Sermon</button>
  </form>

    </div>
  </div>
</div>

<%- include("../partials/footer") %>
