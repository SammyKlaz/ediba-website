<%- include("partials/header") %>

<h1 id = "section-title" class="section-title">ABOUT OUR CHURCH</h1>

<div class="centered">
  <p>
    The Presbyterian Church of Nigeria, Ediba Qua Parish,
    is committed to the preaching of the Gospel,
    discipleship, and service to God and humanity.
  </p>

  <hr class="my-4">

  <h2 class="section-subtitle">OUR MISSION</h2>

  <p>
    To raise faithful believers,
    teach the Word of God,
    and build a Christ centered community.
  </p>

  <hr class="my-4">

  <h2 class="section-subtitle">CHURCH ARMS (MINISTRIES)</h2>

  <div class="grid-4 mt-4">
    <div class="arm-card">
      <img src="/images/mca_logo.jpg" alt="MCA" class="card-img">
      <div class="arm-card-body">
        <h3> MCA</h3>
        <p>
          Men Christian Association.
          This arm focuses on the spiritual growth
          and responsibility of men in the church.
        </p>
      </div>
    </div>

    <div class="arm-card">
      <img src="/images/women_logo.jpg" alt="Women's Guild" class="card-img">
      <div class="arm-card-body">
        <h3> WOMEN'S GUILD</h3>
        <p>
          The Women's Guild is dedicated to nurturing
          godly women through prayer, service, and leadership.
        </p>
      </div>
    </div>

    <div class="arm-card">
      <img src="/images/cgit_logo.jpg" alt="C.G.I.T" class="card-img">
      <div class="arm-card-body">
        <h3> C.G.I.T</h3>
        <p>
          Christian Girls in Training.
          This arm mentors young girls in Christian values,
          discipline, and faith.
        </p>
      </div>
    </div>

    <div class="arm-card">
      <img src="/images/pypan_logo.jpg" alt="PYPAN" class="card-img">
      <div class="arm-card-body">
        <h3> PYPAN</h3>
        <p>
          Presbyterian Young People Association of Nigeria.
          This group empowers youths spiritually,
          socially, and morally.
        </p>
      </div>
    </div>
  </div>

  <hr class="my-5">

  <h2 class="section-subtitle">MEMBERSHIP</h2>

  <% if (membership) { %>
    <p>
      Membership of the parish cuts across all mission stations
      and congregations which include Idundu,
      Akai Efa, and Edim Otop.
      We have a total of
      <strong><%= membership.membership_total %></strong>
      members in the year
      <strong><%= membership.membership_year %></strong>.
    </p>
  <% } else { %>
    <p class="text-muted">
      Membership information is currently unavailable.
    </p>
  <% } %>

  <hr class="my-5">

  <h2 class="section-subtitle">MINISTER IN CHARGE</h2>

<% if (ministerInCharge) { %>
  <div class="minister-incharge-card">
    <div class="minister-incharge-row">
      <div class="minister-incharge-image">
        <img
          src="<%= ministerInCharge.photo %>"
          alt="<%= ministerInCharge.name %>"
        >
      </div>
      <div class="minister-incharge-content">
        <h3><%= ministerInCharge.name %></h3>
        <p><%= ministerInCharge.short_intro %></p>
        <a href="/about/minister-in-charge/<%= ministerInCharge.slug %>" target="_blank" class="btn-incharge">
          Read full profile
        </a>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="minister-incharge-alert">
    Minister in charge information will be updated soon.
  </div>
<% } %>


  <hr class="my-5">

  <h2 class="section-subtitle">OTHER MINISTERS</h2>

  <% if (otherMinisters.length === 0) { %>
    <p class="text-muted">No other ministers available yet.</p>
  <% } else { %>
    <div class="grid-3">
      <% otherMinisters.forEach(minister => { %>
        <div class="minister-card">
          <img
            src="<%= minister.photo %>"
            alt="<%= minister.name %>"
          >
          <h4><%= minister.name %></h4>
          <p class="text-muted"><em>(<%= minister.position %>)</em></p>
        </div>
      <% }) %>
    </div>
  <% } %>

  <hr class="my-5">

  <h2 class="section-subtitle">OUR BELIEF</h2>

  <p>
    We believe in the Holy Trinity,
    the authority of the Bible,
    and salvation through Jesus Christ.
  </p>
  <p>
    Our church upholds the sacraments of Baptism and Holy Communion
    as essential practices of the Christian faith.
  </p>
</div>

<%- include("partials/footer") %>
