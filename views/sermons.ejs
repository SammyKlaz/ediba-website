<%- include("partials/header") %>

<h1 class="sermon-title">Sermons</h1>

<% if (sermons.length === 0) { %>
  <div class="alert alert-info" style="margin-bottom: 1.5rem;">
    <p>No sermons yet.</p>
  </div>
<% } else { %>
  <div class="sermons-grid">
    <% sermons.forEach(sermon => { %>
      <div class="sermon-list-card">
        <div class="sermon-list-content">
          <h3 class="sermon-title-list">
            <a href="/sermons/<%= sermon.slug %>">
              <%= sermon.title %>
            </a>
          </h3>

          <p class="sermon-passage-list">
            <strong>📖 Passage:</strong> <%= sermon.bible_passage %>
          </p>

          <p class="sermon-date-list">
            <strong>📅 Date:</strong> <%= new Date(sermon.sermon_date).toDateString() %>
          </p>

          <% if (sermon.speaker) { %>
            <p class="sermon-speaker-list">
              <strong>🎤 Speaker:</strong> <%= sermon.speaker %>
            </p>
          <% } %>

          <% if (sermon.video) { %>
            <video width="100%" height="250" controls class="sermon-video-list">
              <source src="<%= sermon.video %>" type="video/mp4">
              Your browser does not support the video tag.
            </video>
          <% } %>

          <div class="sermon-list-footer">
            <p class="sermon-engagement-list">
              💬 <%= sermon.comment_count %> <%= sermon.comment_count == 1 ? 'comment' : 'comments' %> | 👍 <%= sermon.like_count %> <%= sermon.like_count == 1 ? 'like' : 'likes' %>
            </p>

            <a href="/sermons/<%= sermon.slug %>" class="sermon-btn">Watch Full Sermon</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include("partials/footer") %>



